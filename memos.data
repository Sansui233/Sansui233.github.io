[{"_1":2},"routes/memos",{"_3":4},"data",{"_5":6,"_97":98,"_10":105,"_179":180},"memos",[7,24,32,40,48,56,64,72,80,89],{"_8":9,"_10":11,"_13":14,"_15":16,"_17":18,"_20":21,"_22":23},"id","2026-05-20 18:48:05","tags",[12],"分享","imgs_md",[],"sourceFile","","csrIndex",[19,19],0,"word_count",225,"content_jsx","\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    a: \"a\",\n    blockquote: \"blockquote\",\n    br: \"br\",\n    li: \"li\",\n    p: \"p\",\n    ul: \"ul\",\n    ...props.components\n  }, {Tag} = _components;\n  if (!Tag) _missingMdxReference(\"Tag\", true);\n  return _jsxs(_Fragment, {\n    children: [_jsxs(_components.p, {\n      children: [_jsx(Tag, {\n        text: \"分享\",\n        children: \"#分享\"\n      }), \" 引用 \", _jsx(_components.a, {\n        href: \"https://daily.xlab.app/d/20260518/\",\n        children: \"透明日报\"\n      }), \" 的文章：\"]\n    }), \"\\n\", _jsxs(_components.blockquote, {\n      children: [\"\\n\", _jsxs(_components.p, {\n        children: [\"人工智能并没有制造新的教育问题，而是让旧问题变得不容忽视。早在第一个语言模型训练出来之前，我们的教育机构就已经存在着奖励表现而非理解、奖励流利而非深度、奖励形式而非真正投入的习惯。人工智能只不过是将这些习惯工业化并加速化，直到它们的空洞本质变得无可辩驳\", _jsx(_components.br, {}), \"\\n\", \"这或许是它最出人意料的馈赠。如果这场变革迫使我们回归教育的本质——培养能够提出真正问题、谨慎判断并对真理负责的人才——那么，人工智能时代或许会出人意料地成为教育革新的时代\"]\n      }), \"\\n\"]\n    }), \"\\n\", _jsxs(_components.ul, {\n      children: [\"\\n\", _jsx(_components.li, {\n        children: _jsx(_components.a, {\n          href: \"https://www.ncregister.com/commentaries/schnell-repairing-the-ruins\",\n          children: \"Repairing the Ruins: Why AI Can’t Replace Education\"\n        })\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"嗯，好精准……\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\nfunction _missingMdxReference(id, component) {\n  throw new Error(\"Expected \" + (component ? \"component\" : \"object\") + \" `\" + id + \"` to be defined: you likely forgot to import, pass, or provide it.\");\n}\n",{"_8":25,"_10":26,"_13":27,"_15":16,"_17":28,"_20":30,"_22":31},"2026-05-14 20:49:09",[],[],[19,29],1,450,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"说一下这一段时间干什么吧，因为我自己也记不住，自打我爸来过两次，睡眠就彻底被打乱了。之前好歹是缓慢偏移，现在的感觉是每天都在倒时差，对着手表上零星小睡、无睡眠、清醒多次的长睡眠发呆。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"昨天又购入了个垃圾服务器，说是有 ipv6 家宽，结果一看 ipv6 支持性好差。把初始化运维的脚本大改了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"……写了几句微信消息来了，不知道是公司的还是导师的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"前几天……忘了，感觉就是在路上，很热，极度的困，很重的书包，不知道在改什么，趴着睡，无法停止的灾难化思维，厕所。正常人很难理解知道不等于做到这件事，我指的是对于相当重大的事件。我是很难理解有人对于任何事都能马上做到，不想做的也能。有人是通过想到做什么就去做的训练强制跳过判断过程。我试过，这要求我必须要持续想着“任何事情立马去做不判断任何环境变量”这件事。一旦停止想这条规则，或者有什么事忽略了这条规则，就做不到。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"把 Obsidian 编辑模式的样式改了，改得和渲染模式有几乎相同的排版了。感觉这么多年，主题都是交给第三方了。但第三方没有这种编辑模式下距离也比较宽松的渲染。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"Obsidian 同步也换到自己的服务器上了，用的 livesync。GPT 说这个插件是面向技术用户。可能“面向技术用户”是交互做不好的高情商说法……\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":33,"_10":34,"_13":35,"_15":16,"_17":36,"_20":38,"_22":39},"2026-05-11 23:34:14",[],[],[19,37],2,207,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"被问到为什么，有时候会是默不作声的，因为对方并不需要真的在问你为什么，只是一种施压，想要的结果只是强迫你服从。如果你真的当为什么回答，好好说自己原因，后果只会被骂。只有表示服从才是令人满意的，只有服从才算解决方案。对于这类人就是如此，问为什么从来不是讨论的语义，那么讨论就没有任何意义，要么沉默要么爆发。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"人总之自以为超越其他物种，可我觉得对于很多人并没有差别。语言交流不比肢体交流高贵，语言暴力也和肢体暴力没什么差别。拿着语言干着和肢体一模一样的事情，\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":41,"_10":42,"_13":43,"_15":16,"_17":44,"_20":46,"_22":47},"2026-05-03 13:47:51",[],[],[19,45],3,251,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"这以前就是遇到想学的东西就会学。但是最近两年，对所有想学的东西也态度都是，这个东西跟学了有什么用呢，不管你学多少还不是被死命催回家。你了解大模型训练有什么用呢，了解 Agent 开发又有什么用呢，你不了解又有什么损失了。0，完全是 0。学习的反馈机制完全被打破了，以前还觉得自己说又学到了东西，但无数次问你说有什么用后，你说的用途别人说不成立，真的会觉得没用。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"就是这样，你做了东西，没有竞品？用途不成立。有竞品？你又怎么和大公司（有背景或者资金雄厚的任意一方）比？从写论文到学习技能都是这样，最后你只敢说自己写的是练手的玩具，也失去了把东西抠细的动力，马马虎虎草草收场。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":49,"_10":50,"_13":51,"_15":16,"_17":52,"_20":54,"_22":55},"2026-04-21 19:56:52",[],[],[19,53],4,152,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"我不喜欢vscode 左侧边默认给你放一排按钮的设计，只有 vscode 和专业软件可以接受，日常的软件用这种设计我就有点抓狂。一是侧栏的图标不带文字，很多不是通用功能，没有统一的语义解释，经常都不知道是干什么的，就像老年人看手机基本不知道各种图标代表什么一样。二是，为什么日常上个网还要给我一种很专业的在写代码的感觉😭一看就有一堆隐藏的 Panel，我恐 Panel 了\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":57,"_10":58,"_13":59,"_15":16,"_17":60,"_20":62,"_22":63},"2026-04-17 16:14:00",[],[],[19,61],5,214,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"还有 21 小时 45 分钟又要裸考，我要怎么安排。睡 8 小时，剩12小时45分钟。 三顿饭算2小时。剩10小时45分钟，写8小时论文，每50分钟休息15分钟。然后就去裸考。考完出门接待吃饭睡觉。不对，我还要洗头洗澡打扫卫生，至少划去两小时。差不多是满打满算一整天就这么过去了。一天过去什么都干不了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"啊忘了我还想看浪姐。但不想给芒果开会员，真的气死我了黑幕不要太明显了好吧，全开麦改live，最强的组被闭麦个人排名下滑……只能说芒果选了弹幕最多的打法，每播一期都会替一个输的人感到不甘。怎么输的简直没法理解。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":65,"_10":66,"_13":67,"_15":16,"_17":68,"_20":70,"_22":71},"2026-04-17 00:25:47",[],[],[19,69],6,75,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"6小时激情写了6000多字小说大纲。如果不是我发现自己太容易去抠了，克制住只写大纲别写对话，我觉得可以写一整天写一两万字。所以到底为什么写小说能这样？写论文就不能呢……\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":73,"_10":74,"_13":75,"_15":16,"_17":76,"_20":78,"_22":79},"2026-04-15 20:59:16",[],[],[19,77],7,843,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    a: \"a\",\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"今天把 Mac 整理了一下，把 Hermes 挂上了；这篇博文就是我在 Telegram 上让 Hermes 发的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"（等下不是……你怎么还顺便给我润色还改了口癖？？我看着感觉我瞬间变成了 AI 幻觉系老板。下面请欣赏有股微妙 GPT 味的 memo）\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"我之前对 clawbot 也没什么兴趣，主要是我一直觉得“压缩上下文当记忆”这套方案特别烂。Agent 真正该记的不是知识，更不是压缩后已经变味的知识，网上搜索和 wiki 查询显然更靠谱。真正值得记的是工作流逻辑和用户偏好。Anthropic 提出的 Skill 在这里确实功不可没。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"Hermes 说自己是在“进化”，但我觉得这个词太笼统了。它更符合我对学习的定义：快速形成可靠工作流，并让 agent 快速命中。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"之前所有东西几乎都离不开上下文和 RAG。我还是不看好 RAG，也不看好把压缩上下文当记忆；这两套东西本质上都像许愿机。Hermes 至少能一次拿到高密度、可实践的信息，记录下来的 skill 也是高密度、可实践的信息。这和 RAG 流、压缩上下文记忆流有很本质的区别。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"当然，组织 skill 依旧需要架构能力，也不是想到 skill 套 skill 就能做得很好。目前 skill 调用判断完全依托于 LLM，prompt 的 weight 是不可调的，skill 一多就会有噪音，占上下文，还会影响模型效果。但这个问题是能解决的。要么大模型继续发展，要么工程方向继续推进；就算模型硬件成本真的到头了，训练个 skill PEFT，把工具和记忆对 memory 窗口的挤占问题解决掉，也完全是可行的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"这是我第一次感觉到 AI 的应用流程开始变可靠了。从成本到架构方式到落地到发展方向，不再全是些许愿不可控的东西了。唯一的问题还是出在大模型那边，稳不下来的许愿池。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"你会发现这些 agent 接 ds 和 glm 效果都不太好，还不如 gpt 5.4 mini。国外的模型已经在向工具调用方向去特化训练了。虽然说数据可以蒸馏，但是一直蒸就会一直造成这种吃屎的赶不上热乎的现象……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"国内也没可能出现搞研究/训练和工程一体化的独角兽公司。硅谷那种环境国内复刻不了，也并不适合国家的体系。即便到民营企业，每家大公司都有研发部门，界限也划得太清了，研发卷研发的产品卷产品的，锤子是锤子螺丝是螺丝。只除了一家，第一次面试的超大包 offer，流动超大、内部废掉的产品超多、重组也超多的那家，确实做出了一些很棒的东西。现在大概已经进不去了，因为五年过去我已经极速腐化了，简历也从不断被捞变成废纸一张了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"还看到个有意思的：\"\n    }), \"\\n\", _jsxs(_components.p, {\n      children: [\"0424  - \", _jsx(_components.a, {\n        href: \"https://mp.weixin.qq.com/s?__biz=MzA5NDYyNDI0MA==&mid=2651960454&idx=1&sn=4f80bd8d5539a8888c3586bf8bc6a36e&poc_token=HFZS6mmjLUQ3V8oeJs8ZbjxdLzWGyA8gfKP2H6Gx\",\n        children: \"我们发现了 Hermes Agent 的第一个远程代码执行漏洞，但这已经不重要了\"\n      })]\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":81,"_10":82,"_13":84,"_15":16,"_17":85,"_20":87,"_22":88},"2026-04-13 20:25:01",[83],"博客",[],[19,86],8,439,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    li: \"li\",\n    p: \"p\",\n    ul: \"ul\",\n    ...props.components\n  }, {Tag} = _components;\n  if (!Tag) _missingMdxReference(\"Tag\", true);\n  return _jsxs(_Fragment, {\n    children: [_jsxs(_components.p, {\n      children: [_jsx(Tag, {\n        text: \"博客\",\n        children: \"#博客\"\n      }), \" 关于全文搜索功能，其实有考虑很多，毕竟我是既要又要的类型\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"后端：全静态没有服务器，不能有数据库。这样我就不用搞维护了。索引构建时间不要太长，不然我懒得等 build。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"前端：索引传输体积要小，UI 组件体积要小，网络下载时间才是网页杀手。准确度属于搜得到就行。\"\n    }), \"\\n\", _jsxs(_components.ul, {\n      children: [\"\\n\", _jsx(_components.li, {\n        children: \"全静态没有服务器 -> 我需要提前构建索引文件。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"索引构建时间不要太长 -> 不要用过于复杂的算法。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"索引传输体积要小 -> 用了复杂的算法全文索引会更大，索引就是空间换时间的。所以不要搞倒排和分词了。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"UI 组件体积要小 -> 不要用特别复杂的匹配算法。这也和索引简易程度相关。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"准确度 -> 关键字对了就行，时效性排序，简单又很可靠。不需要语义近似权重相关性，又不是谷歌。\"\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"所以最佳方案就是传 markdown 全文，把非语义URL、语法标记这种给去掉的全文 ……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"如果写了几万篇怎么办呢？emm，就是给 index 分块，不用一次把数据库搜完，搜个十篇的就行，找不到再搜下一个 index。根本到不了那一天好吧！连载个 40 万字的小说也就 1M 而已，压缩后也就三、四百 K，不要太提前焦虑了，简单的东西反而更实用……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"为啥没用 Flex Search 一类的库？ 他们太复杂了，索引体积也是成倍的，还要一直更新包，动不动给你报依赖的安全问题，算是得不偿失吧。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\nfunction _missingMdxReference(id, component) {\n  throw new Error(\"Expected \" + (component ? \"component\" : \"object\") + \" `\" + id + \"` to be defined: you likely forgot to import, pass, or provide it.\");\n}\n",{"_8":90,"_10":91,"_13":92,"_15":16,"_17":93,"_20":95,"_22":96},"2026-03-27 23:55:23",[],[],[19,94],9,50,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"好了，我觉得还很重要的一点是，早睡，不管多早起，到半夜，由于是因为有事情做才熬到半夜，容易整得人思考人生思考崩溃。\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n","info",{"_5":99,"_10":100,"_101":102,"_103":104},337,11,"imgs",21,"pages",34,[106,120,130,135,142,152,156,161,168,172,176],{"_107":12,"_108":109},"name","memoIds",[9,110,111,112,113,114,115,116,117,118,119],"2026-01-25 19:09:16","2026-01-24 02:47:21","2026-01-19 21:09:44","2026-01-11 06:42:02","2026-01-09 03:25:00","2025-12-28 02:41:52","2025-12-15 10:53:00","2025-11-20 00:00:01","2025-11-16 05:39:33","2025-07-25 00:48:53",{"_107":83,"_108":121},[81,122,123,124,125,126,127,128,129],"2026-01-04 03:34:48","2026-01-01 22:53:40","2024-10-16 18:36:24","2024-08-23 08:18:14","2023-11-06 21:20:06","2023-11-05 21:04:56","2023-10-29 01:13:43","1980-01-01 00:48:28",{"_107":131,"_108":132},"TODO",[133,134],"2026-03-11 15:25:43","2026-01-18 18:05:29",{"_107":136,"_108":137},"react",[138,139,140,141],"2026-01-10 03:19:55","2026-01-08 14:14:49","2026-01-04 20:32:00","2023-11-08 01:30:55",{"_107":143,"_108":144},"工具",[145,146,147,148,149,150,151],"2025-12-18 02:58:11","2024-02-18 01:19:32","2023-12-27 18:09:43","2023-11-29 03:12:05","2023-11-21 00:57:14","2023-11-02 22:20:54","2023-08-30",{"_107":153,"_108":154},"字体",[155],"2025-07-31 02:40:38",{"_107":157,"_108":158},"游戏",[159,160],"2025-01-05 00:51:17","2024-12-08 00:12:16",{"_107":162,"_108":163},"沉思",[164,165,166,167],"2024-02-28 17:24:54","2024-02-22 15:36:59","2024-02-13 16:01:25","2024-02-09 00:34:23",{"_107":169,"_108":170},"书",[171],"2024-02-16 00:17:38",{"_107":173,"_108":174},"故事",[175],"2023-12-10 06:42:56",{"_107":177,"_108":178},"漫画",[126],"source","SSG"]
