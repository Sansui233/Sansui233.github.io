[{"_1":2},"routes/memos",{"_3":4},"data",{"_5":6,"_97":98,"_10":105,"_178":179},"memos",[7,24,32,40,48,56,64,72,80,88],{"_8":9,"_10":11,"_13":14,"_15":16,"_17":18,"_20":21,"_22":23},"id","2026-04-13 20:25:01","tags",[12],"博客","imgs_md",[],"sourceFile","","csrIndex",[19,19],0,"word_count",439,"content_jsx","\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    li: \"li\",\n    p: \"p\",\n    ul: \"ul\",\n    ...props.components\n  }, {Tag} = _components;\n  if (!Tag) _missingMdxReference(\"Tag\", true);\n  return _jsxs(_Fragment, {\n    children: [_jsxs(_components.p, {\n      children: [_jsx(Tag, {\n        text: \"博客\",\n        children: \"#博客\"\n      }), \" 关于全文搜索功能，其实有考虑很多，毕竟我是既要又要的类型\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"后端：全静态没有服务器，不能有数据库。这样我就不用搞维护了。索引构建时间不要太长，不然我懒得等 build。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"前端：索引传输体积要小，UI 组件体积要小，网络下载时间才是网页杀手。准确度属于搜得到就行。\"\n    }), \"\\n\", _jsxs(_components.ul, {\n      children: [\"\\n\", _jsx(_components.li, {\n        children: \"全静态没有服务器 -> 我需要提前构建索引文件。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"索引构建时间不要太长 -> 不要用过于复杂的算法。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"索引传输体积要小 -> 用了复杂的算法全文索引会更大，索引就是空间换时间的。所以不要搞倒排和分词了。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"UI 组件体积要小 -> 不要用特别复杂的匹配算法。这也和索引简易程度相关。\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"准确度 -> 关键字对了就行，时效性排序，简单又很可靠。不需要语义近似权重相关性，又不是谷歌。\"\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"所以最佳方案就是传 markdown 全文，把非语义URL、语法标记这种给去掉的全文 ……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"如果写了几万篇怎么办呢？emm，就是给 index 分块，不用一次把数据库搜完，搜个十篇的就行，找不到再搜下一个 index。根本到不了那一天好吧！连载个 40 万字的小说也就 1M 而已，压缩后也就三、四百 K，不要太提前焦虑了，简单的东西反而更实用……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"为啥没用 Flex Search 一类的库？ 他们太复杂了，索引体积也是成倍的，还要一直更新包，动不动给你报依赖的安全问题，算是得不偿失吧。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\nfunction _missingMdxReference(id, component) {\n  throw new Error(\"Expected \" + (component ? \"component\" : \"object\") + \" `\" + id + \"` to be defined: you likely forgot to import, pass, or provide it.\");\n}\n",{"_8":25,"_10":26,"_13":27,"_15":16,"_17":28,"_20":30,"_22":31},"2026-03-27 23:55:23",[],[],[19,29],1,50,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"好了，我觉得还很重要的一点是，早睡，不管多早起，到半夜，由于是因为有事情做才熬到半夜，容易整得人思考人生思考崩溃。\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":33,"_10":34,"_13":35,"_15":16,"_17":36,"_20":38,"_22":39},"2026-03-37 04:07:00",[],[],[19,37],2,612,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"除了 Day One，还真的只有这里让我有记录的欲望了了。 notion 好慢要选分类，也不能马上看昨天和前天的那些黑历史。基本记录到 notion 的东西记完就忘。我还搞了week plan 模版，评价是不如小本本来得方便。社交平台的数据始终不是我的。刚才想说很多话，到了这里就偃旗息鼓了，至少有这个博客永远是你的自己的，也没有登味的人让你干这干那，足够清爽不是吗。要玩就在这里玩好了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"想法永远不相通。她觉得我是没自信，不，我只是对于要一直待在那种充满老登的环境感到绝望。我想去找人一起玩，让我回家比死了还难受。我讨厌为了老登打扮讨厌敬酒讨厌各种被迫参与的关系讨厌虚伪讨厌裙带关系讨厌一切不能投入的事情讨厌不能写代码或者不能创作，光是想想就觉得要窒息了。“你就是缺乏锻炼”“我把你保护地太好了”我真的听了想吐，我不知道别的，但我听了想吐。我无所谓来这里的人是什么看法，起码我给自己留了个完全衷于自我的地方，我没有当键盘侠没有骂别人，我只想好好学东西用学的东西养活自己，我到底犯了什么事要找个把我讨厌的所有 buff 叠满的工作。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"我现在对完成的任何事情都没有成就感，好像只是在赎罪的一样，把身上的罪孽一件一件先清掉而已。不要提什么考虑自己，罪人是没有未来的，赎罪就可以了，和在牢里度过余生没什么区别。极端吗？可我没去别的地方骂人，顶多是当一个只会拉点屎的可回收生物。可悲吗？可我没真的坐牢，我又有手有脚有学历有技能学东西还快没欠款远没到 35。那你为什么就没有未来了呢？\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"也许我该去北医六院看看，开个证明后做长期心理咨询了。但我不记得，我连收拾自己的力气都没有。真没想到想到要面这个试就会整发病。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":41,"_10":42,"_13":43,"_15":16,"_17":44,"_20":46,"_22":47},"2026-03-25 20:39:36",[],[],[19,45],3,1180,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    a: \"a\",\n    p: \"p\",\n    strong: \"strong\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: _jsx(_components.strong, {\n        children: \"钱能让你接受网暴吗？\"\n      })\n    }), \"\\n\", _jsxs(_components.p, {\n      children: [\"看了 UP 主瑞瑞狸\", _jsx(_components.a, {\n        href: \"https://space.bilibili.com/13334303/lists/2051298?type=season\",\n        children: \"抓键盘侠一系列的视频\"\n      }), \"，系列标题是《勇气是人类的赞歌》。开始是觉得这个 UP 的记仇周期长达十几年也是很不寻常了，放现实生活中我大概也觉得他是神人，但作为视频题材又很好，文案的度把握得也刚好。看完感想是，对于真人，不要刻板地去看待任何人。多接触真实的人，大部分人都比在网上看社区温和得多，也并非不可理喻的人。\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"不过最令我印象深刻的不是他当面对峙键盘侠的几期，是他让学员去体验网暴的选题。三个学员都失败了，第1个是偏理想主义，第2个是心理年龄过于年轻了，第3个是有点站着说话不腰疼。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"最开头的视频提到这三个学员有一个共同点：“只要给够钱，什么都能做”。在近些年这是相当流行的观点。以前还会说“钱不是万能，但没有钱万万不能”。但现在流行的是“钱是万能”，有钱能上好学，受好教育，上好班，打好关系，如果做不到，就是钱不够多。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"以“钱是万能”的观点看，可以说是博主给的钱太少了，如果像Mr Beast 先生那样周期拉长，挂上百万悬赏，也许有人能坚持下来。但就这三个学员而言，我认为依旧不好说，他们并不是自己说的那样认为钱可以让他们违背自己承受网暴的人。应该说大部分的人都是如此。如果博主打算挑选的还是普通人而不是神人，能成功的几率很小依然很小。我一直觉得做人文类自媒体的自身就得有一些神人因素在里面，比如小狸能记仇十几年（没有褒贬客观描述）并且还能坦然承认；要不，就是见多了给打磨光滑了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"1号学员是一个高个小帅哥。小帅哥博主家庭现状是男弱女强。我觉得算是有点理想主义在里面，这个理想又太健康了，也正是这样的性格使得1号能非常和睦地接受现有的家庭结构。只不过发到抖音这种平台，就不得不真正地去认清更现实中的各种各样的有色滤镜。一旦认识更现实更残酷的观念后，理想的相处模式可能会一去不回，不过没想到吵架2周就到快离婚了……这么说是因为1号之前的状态会让我幻视某个聊到现实一点的话题就会吵的人，就像1号被网暴他的观念影响后，开启夫妻吵架也非常快。还是祝福他们，其实脱离自媒体还是有希望过得好的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"2号女生，网暴给她的影响没有家庭大。有人是代入博主是觉得她是神人莫名其妙，但我作为一个境遇有点像人的能对这个女生的处境感同身受。她觉得晚上被网暴哭这种事情没什么，因为她家庭也很窒息，这么扛压扛惯了，大概网上骂她的点还不如家里骂她的点精准。而且就算小狸对她做这事十分斥责，她也是绝对不会因此怕小狸的，她想反抗但不敢，甚至和母亲没有一丝争辩，小狸是代替她说出自己不敢说的“叛逆”话的好人角色。她目前最大的问题还真的不是她认为的钱，假设她“叛逆”一点，把原生家庭拍出一个自述系列也能火，但目前来看没这个可能。小狸都怕她妈了更不可能去这么“不良引导”她女儿，姑娘自己也没可能自愿拍，要是掌握不好度一堆人骂她和她家人，又能承受吗？\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"3号（目前已经不）姓张的小姐线下真实确实有点吓人。但如果说这是个赏金百万的长期项目，在这三个人里我觉得她是最有可能达成的，前提是有人拉她回来。现在只是她见这种人见得少了，假以时日和对方对轰久了，迟早会由于内容与思考的深入而懒得去和对方对线的。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":49,"_10":50,"_13":51,"_15":16,"_17":52,"_20":54,"_22":55},"2026-03-22 20:55:04",[],[],[19,53],4,804,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"最近大家都在养龙虾（openclaw）。我养不动，不知道养来干嘛，评价是一代人有一代人的笔记软件。很多人会说是去探索落地的场景，这是没错，但在新技术迭代期，养龙虾和正想做点什么事其实是矛盾的。如果我研究龙虾怎么用仅仅为了探索哪里用，意味着我太闲了，我没有聚焦于当下更实际的任务，很容易陷入一种伪装的效率与伪装的努力上。我认为最好的方式是，在做事情感到烦躁时，想想龙虾能不能帮忙解决，如果能那就是一个好用法。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"但很多时候又觉得这些都不重要。太多人是为了“可能有用”而买单，也有人为了当下的流量收益而买单。就像短期股一样，不能非常理性长期的去看待一支股背后公司、技术发展前景，而是要看当下的宣传怎么样，有多少人关注这事。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"不过这些事情其实也就在比较关注技术的圈子会让人感到身边即世界。而和其他领域的人说话时，他们知道元宝千问，会关注自己要用的AI，但也不太关注龙虾。这也是为什么一些小老板更看重龙虾的价值，他“前沿”，用起来又没什么技术门槛，还能裁掉员工，三重buff。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"虚拟内容生产的赛道本身就很卷了，我觉得和之前的科技有着更本质的区别。在二十几年前是可以看到通信/计算机行业将会发展的，因为实打实可以跨距离交换多种信息。交换信息本身就是人类的生活、劳动一直在做的事情。流水线压低成本也是实体经济强相关。但从没有听说过，1 天画完图（摄影机）能让生活变得更好。虚拟技术的发展多了很多的艺术形式，这只是娱乐，人不要沉溺于娱乐并假装自己做的是实事。也许是我老了，我确实不知道龙虾能有什么用，要说机器人、无人机、VR 有用我还是会相信，尽管发展起来有些困难。怎么说都绝对不应该是龙虾。信息交换的赛道已经到头了，壁垒在人。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"说来我对用什么笔记软件也无所谓了，只要能实现我常用的几个功能就行：1能搜索，2能按时间线复习，3能打页面标签，4能自己整理页面层级。其实能把 2 做好的，只有卡片式写笔记的可以。但老实说卡片式笔记挺不符合长期体系化笔记诉求的，反映到向上汇报时结构也容易支离破碎，这是我用大纲式笔记后感觉唯一的问题。但传统笔记没有一个能做到自动生成最近的笔记卡片。所以，Notion 能不能开放api……整个插件什么的。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":57,"_10":58,"_13":59,"_15":16,"_17":60,"_20":62,"_22":63},"2026-03-22 17:47:06 ",[],[],[19,61],5,217,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"感觉可以整个视监后端在 Cloudflare pages 上……然后这页面改一下做个视监。想法一大堆，你写了吗，写了吗？？其实改起来很快，但得有个时间开始废寝忘食地改……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"而且这个页面的设计我又不满意了。不如说是以前也没有很满意，但现在更不满意了，感觉没有什么生气。但是设计又是很难的事情……最简单的方案肯定是用颜色，在平设里色彩情绪是最有用的没有之一。二是字体和行高。大家都会喜欢精致一点的东西，需要有足够小的元素，特别是在大字体时，要么字体有边角装饰要么有足够小的字。。动画是次要的，一是容易卡二是抢内容焦点。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":65,"_10":66,"_13":67,"_15":16,"_17":68,"_20":70,"_22":71},"2026-03-20 00:44:49",[],[],[19,69],6,43,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"无可否喜欢无聊的，纯平面的设计，体积一多了就感觉有点烦躁，像家里多了一大堆难以打扫的垃圾一样。\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":73,"_10":74,"_13":75,"_15":16,"_17":76,"_20":78,"_22":79},"2026-03-16 20:32:29",[],[],[19,77],7,111,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"小时候因为比较喜欢说随便，有人就给我取外号就叫随便，但我是真随便。后面没有那么随便了，因为老说随便也会给人困扰，意味着所有小事都给别人做决策，只要对方有点良心，做决策的也是累的，只有 NPD 会狂喜。但 NPD 不开心，那现在我还是随便，也只能是随遇而安的意思。\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":81,"_10":82,"_13":83,"_15":16,"_17":84,"_20":86,"_22":87},"2026-03-13 23:00:17",[],[],[19,85],8,1673,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"难受一会儿跑去看完全不用动脑只会治愈的大黄直播，啊真好。然后跑去看林鸽的视频，想起曾经一个没写完的 memo 叫“腾讯为什么做不出二次元游戏”，以及前老板说的他认为米哈游的成功是“懂二次元”，有了点新感受。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"“二次元现在看起来是一个很大众的爱好，但其实从始至终都是一个很小众的东西”。确实如此，首先还是要明确对二次元的理解是什么。时至今日，二次元，或者说，二次元宅文化，作为一个文化符号早就不只是指代画风，而是“故事”与“角色”。如果只说日本动漫画风，你会认为“铁臂阿童木”是二次元作品吗？似乎是动画，但和“二次元”三个字给人的刻板印象相去甚远。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"早年的二次元作品10个里5个在开美少女后宫卖麻辣2个在超雄高中生拯救世界1个在谈校园恋爱1个在开高达还有1个转生到异世界。对于我而言，要素有三点，“青春” + “剧情” + “角色塑造”。青春不是指校园，而是外表年龄和心理年龄，活了几百年的老登都香香的（不）。真正的现实向恋老癖，没有。剧情是一个基本要素，但不突出，只有带有强烈的“角色塑造”才让二次元味真正凸显出来。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"我碰到真二次元的作品其实喜欢不起来，特别是日乙。玩 FGO 前期时让我坚持玩下去的只有一个念头“大家都说神，看看有什么好看的” 。到后期也是基本一开 FGO 的日常就能睡着……如果我是偶尔看到的 FGO，应该玩不到1小时就放弃了。二次元在“角色”上发力有时会将角色高于剧情，此时我就会觉得索然无味只想跳过，但真跳了之后会看不懂又头疼。还有的游戏剧情节奏一直在线，但会让人一直在想为什么驾驶员非要脱衣服，有什么特别的理由吗……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"那米哈游的成功是因为“懂二次元”吗？我觉得不是。我不是说米哈游不懂二次元，只是当时原神的取得的成功反而是来源于非二次元的部分，他是通过二次元以外的东西扩圈的，现在剧情与玩法都越来越偏向于带动画的RPG，也就美术的二次元味还比较重。不过前期我还是能感知到编剧在传说任务里狂卖角色那味，但又因为玩法够多，只当一个卡通风 RPG 游戏玩也还算能玩。只不过当对于角色塑造的执着超过了主流的认知，就会引发争议，“太二次元”才是每次争议时被抨击的点。如果只是做得很“懂二次元”，反而取得无法更大的成功。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"这就得说这就要说到原神的“抄袭”对象——塞尔达旷野之息。野炊是卡通渲染，但这游戏没有特别二次元的要素在里面。野炊出名是因为划世代的视听体验与玩法，和那些10个里5个在开美少女后宫卖麻辣2个在超雄高中生拯救世界1个在谈校园恋爱1个在开高达还有1个转生到异世界相比，完全不具备一般说起“二次元”的印象。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"原神一开始也做得很像纯 RPG——除了美术和抽卡。如果当成一般的游戏去玩，会觉得各种拉，我第一次玩时就是这样的视角，感觉非常一般，但能玩，而且在二次元游戏里，美术确实没得说。但如果是当成加了其他游戏要素的二次元游戏，这个游戏的质量就是断层，这可比 FGO 前期好过多了（不如说你月是公认的没有游戏性，连剧情都不行还玩啥）。我妈曾经毫不掩饰说她看不起日本动漫风格那种粗制滥造的小人，穿得还巾巾掉掉的。但我给她看到的第一个角色，香菱，她觉得很传统很好看。老实说连我都觉得香菱那股结合了二次元味的衣服穿得有点太少了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"而被人诟病的二次元卖角色抽卡，这反而是我最不能理解的一点。之前的二游就是这样的，受众小不走量，利润上限设得很高。原神在一般向的内容中免费，在“二次元”向的内容中收费。换言之，二次元的受众不需要通过这个游戏才被“骗”成氪佬；而不是二次元的受众，也不会因为这个游戏被“逼”成氪佬。能玩的东西很多，为何只因抽卡在那里就视抽卡如洪水猛兽？有人将其视作赌博，但赌博至少骗你能赚到钱，可花钱抽卡去玩游戏明显是稳亏不赚。想了很久，目前不成熟的想法是，人们讨厌预期收益中会亏损的部分，会想补偿回来。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"假设收益固定，告诉你，我们游戏一个版本有两个新角色，每1个版本领养1个角色。当你领了20个角色后，可以兑换一个角色。如果你想要更多角色，则需要购买，原价1000元一个，商城里有优惠券，每月有一次30元抵160元券，68元抵160元券。每年有总计1500抵3000元券……此时瞬间从赌博游戏变成富人游戏，穷鬼一看那玩免费就可以了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"如果把抽卡预期拉到2个版本1限定，则不会有任何失望，多抽到的都是赚到的。况且，这种游戏抽卡唯一的作用就是打高难。只不过国内应试体系对于成绩的追求，到工作各种证书 title 的追求，体现到游戏上似乎也有种收益要拿满的倾向。但当你放弃攀比，回到游戏只是娱乐时，对于游戏赌博的需求应当不复存在。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":89,"_10":90,"_13":92,"_15":16,"_17":93,"_20":95,"_22":96},"2026-03-11 15:25:43",[91],"TODO",[],[19,94],9,226,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  }, {Tag} = _components;\n  if (!Tag) _missingMdxReference(\"Tag\", true);\n  return _jsxs(_Fragment, {\n    children: [_jsxs(_components.p, {\n      children: [\"还是把加锁功能赶紧开发出来吧，一直没有动力做这个事情，因为一但改格式就不可避免地还是会想去优化 memo 的 parsing。还是用的三年前写的 parsing。之前只想着希望性能可以好一点所以一股脑写了一大串过程式的写算法题一样的代码，代价就是当格式变复杂后就会变成难以维护的一大坨。如果是多人维护的非基础库还是不要这样做，性能是相对次要的，可读性第一。 \", _jsx(Tag, {\n        text: \"TODO\",\n        children: \"#TODO\"\n      })]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"更重要的是一想着维护这些，就觉得我又没干正事，不该干。而看论文做PPT投简历向上汇报反馈这一串下来，又没有精力做了，这还不包括搞点社交学点新技能。哪一件都不是简单的事。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\nfunction _missingMdxReference(id, component) {\n  throw new Error(\"Expected \" + (component ? \"component\" : \"object\") + \" `\" + id + \"` to be defined: you likely forgot to import, pass, or provide it.\");\n}\n","info",{"_5":99,"_10":100,"_101":102,"_103":104},329,11,"imgs",21,"pages",33,[106,118,121,134,141,151,155,160,167,171,175],{"_107":12,"_108":109},"name","memoIds",[9,110,111,112,113,114,115,116,117],"2026-01-04 03:34:48","2026-01-01 22:53:40","2024-10-16 18:36:24","2024-08-23 08:18:14","2023-11-06 21:20:06","2023-11-05 21:04:56","2023-10-29 01:13:43","1980-01-01 00:48:28",{"_107":91,"_108":119},[89,120],"2026-01-18 18:05:29",{"_107":122,"_108":123},"分享",[124,125,126,127,128,129,130,131,132,133],"2026-01-25 19:09:16","2026-01-24 02:47:21","2026-01-19 21:09:44","2026-01-11 06:42:02","2026-01-09 03:25:00","2025-12-28 02:41:52","2025-12-15 10:53:00","2025-11-20 00:00:01","2025-11-16 05:39:33","2025-07-25 00:48:53",{"_107":135,"_108":136},"react",[137,138,139,140],"2026-01-10 03:19:55","2026-01-08 14:14:49","2026-01-04 20:32:00","2023-11-08 01:30:55",{"_107":142,"_108":143},"工具",[144,145,146,147,148,149,150],"2025-12-18 02:58:11","2024-02-18 01:19:32","2023-12-27 18:09:43","2023-11-29 03:12:05","2023-11-21 00:57:14","2023-11-02 22:20:54","2023-08-30",{"_107":152,"_108":153},"字体",[154],"2025-07-31 02:40:38",{"_107":156,"_108":157},"游戏",[158,159],"2025-01-05 00:51:17","2024-12-08 00:12:16",{"_107":161,"_108":162},"沉思",[163,164,165,166],"2024-02-28 17:24:54","2024-02-22 15:36:59","2024-02-13 16:01:25","2024-02-09 00:34:23",{"_107":168,"_108":169},"书",[170],"2024-02-16 00:17:38",{"_107":172,"_108":173},"故事",[174],"2023-12-10 06:42:56",{"_107":176,"_108":177},"漫画",[114],"source","SSG"]
