[{"_1":2},"routes/memos",{"_3":4},"data",{"_5":6,"_96":97,"_10":104,"_180":181},"memos",[7,24,32,40,48,56,64,72,80,88],{"_8":9,"_10":11,"_13":14,"_15":16,"_17":18,"_20":21,"_22":23},"id","2026-06-03 05:37:13","tags",[12],"分享","imgs_md",[],"sourceFile","","csrIndex",[19,19],0,"word_count",43,"content_jsx","\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    a: \"a\",\n    li: \"li\",\n    p: \"p\",\n    ul: \"ul\",\n    ...props.components\n  }, {Tag} = _components;\n  if (!Tag) _missingMdxReference(\"Tag\", true);\n  return _jsxs(_Fragment, {\n    children: [_jsxs(_components.p, {\n      children: [_jsx(Tag, {\n        text: \"分享\",\n        children: \"#分享\"\n      }), \" 技术\"]\n    }), \"\\n\", _jsxs(_components.ul, {\n      children: [\"\\n\", _jsxs(_components.li, {\n        children: [\"斯坦福新的AI课程： \", _jsx(_components.a, {\n          href: \"https://cs336.stanford.edu\",\n          children: \"CS336: Language Modeling from Scratch\"\n        })]\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"一共19节，差不多一学期的强度。又出现了，研究生真正的导师。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\nfunction _missingMdxReference(id, component) {\n  throw new Error(\"Expected \" + (component ? \"component\" : \"object\") + \" `\" + id + \"` to be defined: you likely forgot to import, pass, or provide it.\");\n}\n",{"_8":25,"_10":26,"_13":27,"_15":16,"_17":28,"_20":30,"_22":31},"2026-06-02 00:01:45",[],[],[19,29],1,256,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"最近设计偏好有更新。一是因为字体，好像把系统换成更纱黑体后，粗字重实在太粗了，我不确定有多少默认字体有这么粗。二是近两年又在流行弱对比轻盈感，信息密度也比前两年偏高了。我看博客也是开始觉得不忍直视了。draw.io 的预设也全部给变细了一遍。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"又因为 claude 流行的关系，现在全是衬线细字的黄底学术风大家也能接受了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"但是中文还是那个问题，衬线体表现不统一，又不能给网页引入网络字体。所以只能在无衬线的方向上走。有时间我又要搞装修。笑死，根本没修完，还在装修 AO3 。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"AO3 算是地狱级别，原生 DOM 太简单，选择器 Scope 过大相互影响，CSS 的特性支持停留在10年前的水平。给 AO3 写主题是目前的 AI 绝对搞不定的东西。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":33,"_10":34,"_13":35,"_15":16,"_17":36,"_20":38,"_22":39},"2026-05-20 18:48:05",[12],[],[19,37],2,225,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    a: \"a\",\n    blockquote: \"blockquote\",\n    br: \"br\",\n    li: \"li\",\n    p: \"p\",\n    ul: \"ul\",\n    ...props.components\n  }, {Tag} = _components;\n  if (!Tag) _missingMdxReference(\"Tag\", true);\n  return _jsxs(_Fragment, {\n    children: [_jsxs(_components.p, {\n      children: [_jsx(Tag, {\n        text: \"分享\",\n        children: \"#分享\"\n      }), \" 引用 \", _jsx(_components.a, {\n        href: \"https://daily.xlab.app/d/20260518/\",\n        children: \"透明日报\"\n      }), \" 的文章：\"]\n    }), \"\\n\", _jsxs(_components.blockquote, {\n      children: [\"\\n\", _jsxs(_components.p, {\n        children: [\"人工智能并没有制造新的教育问题，而是让旧问题变得不容忽视。早在第一个语言模型训练出来之前，我们的教育机构就已经存在着奖励表现而非理解、奖励流利而非深度、奖励形式而非真正投入的习惯。人工智能只不过是将这些习惯工业化并加速化，直到它们的空洞本质变得无可辩驳\", _jsx(_components.br, {}), \"\\n\", \"这或许是它最出人意料的馈赠。如果这场变革迫使我们回归教育的本质——培养能够提出真正问题、谨慎判断并对真理负责的人才——那么，人工智能时代或许会出人意料地成为教育革新的时代\"]\n      }), \"\\n\"]\n    }), \"\\n\", _jsxs(_components.ul, {\n      children: [\"\\n\", _jsx(_components.li, {\n        children: _jsx(_components.a, {\n          href: \"https://www.ncregister.com/commentaries/schnell-repairing-the-ruins\",\n          children: \"Repairing the Ruins: Why AI Can’t Replace Education\"\n        })\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"嗯，好精准……\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\nfunction _missingMdxReference(id, component) {\n  throw new Error(\"Expected \" + (component ? \"component\" : \"object\") + \" `\" + id + \"` to be defined: you likely forgot to import, pass, or provide it.\");\n}\n",{"_8":41,"_10":42,"_13":43,"_15":16,"_17":44,"_20":46,"_22":47},"2026-05-14 20:49:09",[],[],[19,45],3,450,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"说一下这一段时间干什么吧，因为我自己也记不住，自打我爸来过两次，睡眠就彻底被打乱了。之前好歹是缓慢偏移，现在的感觉是每天都在倒时差，对着手表上零星小睡、无睡眠、清醒多次的长睡眠发呆。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"昨天又购入了个垃圾服务器，说是有 ipv6 家宽，结果一看 ipv6 支持性好差。把初始化运维的脚本大改了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"……写了几句微信消息来了，不知道是公司的还是导师的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"前几天……忘了，感觉就是在路上，很热，极度的困，很重的书包，不知道在改什么，趴着睡，无法停止的灾难化思维，厕所。正常人很难理解知道不等于做到这件事，我指的是对于相当重大的事件。我是很难理解有人对于任何事都能马上做到，不想做的也能。有人是通过想到做什么就去做的训练强制跳过判断过程。我试过，这要求我必须要持续想着“任何事情立马去做不判断任何环境变量”这件事。一旦停止想这条规则，或者有什么事忽略了这条规则，就做不到。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"把 Obsidian 编辑模式的样式改了，改得和渲染模式有几乎相同的排版了。感觉这么多年，主题都是交给第三方了。但第三方没有这种编辑模式下距离也比较宽松的渲染。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"Obsidian 同步也换到自己的服务器上了，用的 livesync。GPT 说这个插件是面向技术用户。可能“面向技术用户”是交互做不好的高情商说法……\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":49,"_10":50,"_13":51,"_15":16,"_17":52,"_20":54,"_22":55},"2026-05-11 23:34:14",[],[],[19,53],4,207,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"被问到为什么，有时候会是默不作声的，因为对方并不需要真的在问你为什么，只是一种施压，想要的结果只是强迫你服从。如果你真的当为什么回答，好好说自己原因，后果只会被骂。只有表示服从才是令人满意的，只有服从才算解决方案。对于这类人就是如此，问为什么从来不是讨论的语义，那么讨论就没有任何意义，要么沉默要么爆发。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"人总之自以为超越其他物种，可我觉得对于很多人并没有差别。语言交流不比肢体交流高贵，语言暴力也和肢体暴力没什么差别。拿着语言干着和肢体一模一样的事情，\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":57,"_10":58,"_13":59,"_15":16,"_17":60,"_20":62,"_22":63},"2026-05-03 13:47:51",[],[],[19,61],5,251,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"这以前就是遇到想学的东西就会学。但是最近两年，对所有想学的东西也态度都是，这个东西跟学了有什么用呢，不管你学多少还不是被死命催回家。你了解大模型训练有什么用呢，了解 Agent 开发又有什么用呢，你不了解又有什么损失了。0，完全是 0。学习的反馈机制完全被打破了，以前还觉得自己说又学到了东西，但无数次问你说有什么用后，你说的用途别人说不成立，真的会觉得没用。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"就是这样，你做了东西，没有竞品？用途不成立。有竞品？你又怎么和大公司（有背景或者资金雄厚的任意一方）比？从写论文到学习技能都是这样，最后你只敢说自己写的是练手的玩具，也失去了把东西抠细的动力，马马虎虎草草收场。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":65,"_10":66,"_13":67,"_15":16,"_17":68,"_20":70,"_22":71},"2026-04-21 19:56:52",[],[],[19,69],6,152,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"我不喜欢vscode 左侧边默认给你放一排按钮的设计，只有 vscode 和专业软件可以接受，日常的软件用这种设计我就有点抓狂。一是侧栏的图标不带文字，很多不是通用功能，没有统一的语义解释，经常都不知道是干什么的，就像老年人看手机基本不知道各种图标代表什么一样。二是，为什么日常上个网还要给我一种很专业的在写代码的感觉😭一看就有一堆隐藏的 Panel，我恐 Panel 了\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":73,"_10":74,"_13":75,"_15":16,"_17":76,"_20":78,"_22":79},"2026-04-17 16:14:00",[],[],[19,77],7,214,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"还有 21 小时 45 分钟又要裸考，我要怎么安排。睡 8 小时，剩12小时45分钟。 三顿饭算2小时。剩10小时45分钟，写8小时论文，每50分钟休息15分钟。然后就去裸考。考完出门接待吃饭睡觉。不对，我还要洗头洗澡打扫卫生，至少划去两小时。差不多是满打满算一整天就这么过去了。一天过去什么都干不了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"啊忘了我还想看浪姐。但不想给芒果开会员，真的气死我了黑幕不要太明显了好吧，全开麦改live，最强的组被闭麦个人排名下滑……只能说芒果选了弹幕最多的打法，每播一期都会替一个输的人感到不甘。怎么输的简直没法理解。\"\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":81,"_10":82,"_13":83,"_15":16,"_17":84,"_20":86,"_22":87},"2026-04-17 00:25:47",[],[],[19,85],8,75,"\"use strict\";\nconst {jsx: _jsx} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    p: \"p\",\n    ...props.components\n  };\n  return _jsx(_components.p, {\n    children: \"6小时激情写了6000多字小说大纲。如果不是我发现自己太容易去抠了，克制住只写大纲别写对话，我觉得可以写一整天写一两万字。所以到底为什么写小说能这样？写论文就不能呢……\"\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n",{"_8":89,"_10":90,"_13":91,"_15":16,"_17":92,"_20":94,"_22":95},"2026-04-15 20:59:16",[],[],[19,93],9,843,"\"use strict\";\nconst {Fragment: _Fragment, jsx: _jsx, jsxs: _jsxs} = arguments[0];\nfunction _createMdxContent(props) {\n  const _components = {\n    a: \"a\",\n    p: \"p\",\n    ...props.components\n  };\n  return _jsxs(_Fragment, {\n    children: [_jsx(_components.p, {\n      children: \"今天把 Mac 整理了一下，把 Hermes 挂上了；这篇博文就是我在 Telegram 上让 Hermes 发的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"（等下不是……你怎么还顺便给我润色还改了口癖？？我看着感觉我瞬间变成了 AI 幻觉系老板。下面请欣赏有股微妙 GPT 味的 memo）\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"我之前对 clawbot 也没什么兴趣，主要是我一直觉得“压缩上下文当记忆”这套方案特别烂。Agent 真正该记的不是知识，更不是压缩后已经变味的知识，网上搜索和 wiki 查询显然更靠谱。真正值得记的是工作流逻辑和用户偏好。Anthropic 提出的 Skill 在这里确实功不可没。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"Hermes 说自己是在“进化”，但我觉得这个词太笼统了。它更符合我对学习的定义：快速形成可靠工作流，并让 agent 快速命中。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"之前所有东西几乎都离不开上下文和 RAG。我还是不看好 RAG，也不看好把压缩上下文当记忆；这两套东西本质上都像许愿机。Hermes 至少能一次拿到高密度、可实践的信息，记录下来的 skill 也是高密度、可实践的信息。这和 RAG 流、压缩上下文记忆流有很本质的区别。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"当然，组织 skill 依旧需要架构能力，也不是想到 skill 套 skill 就能做得很好。目前 skill 调用判断完全依托于 LLM，prompt 的 weight 是不可调的，skill 一多就会有噪音，占上下文，还会影响模型效果。但这个问题是能解决的。要么大模型继续发展，要么工程方向继续推进；就算模型硬件成本真的到头了，训练个 skill PEFT，把工具和记忆对 memory 窗口的挤占问题解决掉，也完全是可行的。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"这是我第一次感觉到 AI 的应用流程开始变可靠了。从成本到架构方式到落地到发展方向，不再全是些许愿不可控的东西了。唯一的问题还是出在大模型那边，稳不下来的许愿池。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"你会发现这些 agent 接 ds 和 glm 效果都不太好，还不如 gpt 5.4 mini。国外的模型已经在向工具调用方向去特化训练了。虽然说数据可以蒸馏，但是一直蒸就会一直造成这种吃屎的赶不上热乎的现象……\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"国内也没可能出现搞研究/训练和工程一体化的独角兽公司。硅谷那种环境国内复刻不了，也并不适合国家的体系。即便到民营企业，每家大公司都有研发部门，界限也划得太清了，研发卷研发的产品卷产品的，锤子是锤子螺丝是螺丝。只除了一家，第一次面试的超大包 offer，流动超大、内部废掉的产品超多、重组也超多的那家，确实做出了一些很棒的东西。现在大概已经进不去了，因为五年过去我已经极速腐化了，简历也从不断被捞变成废纸一张了。\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"还看到个有意思的：\"\n    }), \"\\n\", _jsxs(_components.p, {\n      children: [\"0424  - \", _jsx(_components.a, {\n        href: \"https://mp.weixin.qq.com/s?__biz=MzA5NDYyNDI0MA==&mid=2651960454&idx=1&sn=4f80bd8d5539a8888c3586bf8bc6a36e&poc_token=HFZS6mmjLUQ3V8oeJs8ZbjxdLzWGyA8gfKP2H6Gx\",\n        children: \"我们发现了 Hermes Agent 的第一个远程代码执行漏洞，但这已经不重要了\"\n      })]\n    })]\n  });\n}\nfunction MDXContent(props = {}) {\n  const {wrapper: MDXLayout} = props.components || ({});\n  return MDXLayout ? _jsx(MDXLayout, {\n    ...props,\n    children: _jsx(_createMdxContent, {\n      ...props\n    })\n  }) : _createMdxContent(props);\n}\nreturn {\n  default: MDXContent\n};\n","info",{"_5":98,"_10":99,"_100":101,"_102":103},339,11,"imgs",21,"pages",34,[105,119,131,136,143,153,157,162,169,173,177],{"_106":12,"_107":108},"name","memoIds",[9,33,109,110,111,112,113,114,115,116,117,118],"2026-01-25 19:09:16","2026-01-24 02:47:21","2026-01-19 21:09:44","2026-01-11 06:42:02","2026-01-09 03:25:00","2025-12-28 02:41:52","2025-12-15 10:53:00","2025-11-20 00:00:01","2025-11-16 05:39:33","2025-07-25 00:48:53",{"_106":120,"_107":121},"博客",[122,123,124,125,126,127,128,129,130],"2026-04-13 20:25:01","2026-01-04 03:34:48","2026-01-01 22:53:40","2024-10-16 18:36:24","2024-08-23 08:18:14","2023-11-06 21:20:06","2023-11-05 21:04:56","2023-10-29 01:13:43","1980-01-01 00:48:28",{"_106":132,"_107":133},"TODO",[134,135],"2026-03-11 15:25:43","2026-01-18 18:05:29",{"_106":137,"_107":138},"react",[139,140,141,142],"2026-01-10 03:19:55","2026-01-08 14:14:49","2026-01-04 20:32:00","2023-11-08 01:30:55",{"_106":144,"_107":145},"工具",[146,147,148,149,150,151,152],"2025-12-18 02:58:11","2024-02-18 01:19:32","2023-12-27 18:09:43","2023-11-29 03:12:05","2023-11-21 00:57:14","2023-11-02 22:20:54","2023-08-30",{"_106":154,"_107":155},"字体",[156],"2025-07-31 02:40:38",{"_106":158,"_107":159},"游戏",[160,161],"2025-01-05 00:51:17","2024-12-08 00:12:16",{"_106":163,"_107":164},"沉思",[165,166,167,168],"2024-02-28 17:24:54","2024-02-22 15:36:59","2024-02-13 16:01:25","2024-02-09 00:34:23",{"_106":170,"_107":171},"书",[172],"2024-02-16 00:17:38",{"_106":174,"_107":175},"故事",[176],"2023-12-10 06:42:56",{"_106":178,"_107":179},"漫画",[127],"source","SSG"]
