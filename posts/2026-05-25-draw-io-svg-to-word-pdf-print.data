href:\"https://www.drawio.com/doc/faq/SVG-export-text-problems\",children:\"官网的说明\"}),\"，应该要取消前两项。\"]}),\"\\n\",n(i.img,{src:\"C:%5CUsers%5Clingn%5CDesktop%5C8_padded_padded.png\",alt:\"8_padded_padded\"}),\"\\n\",e(i.p,{children:[\"这样最终效果就完全一致，导出为 PDF 打印后，图表内的文字也和正文一样清晰，而且可以被选中。\\n\",n(i.img,{src:\"C:%5CUsers%5Clingn%5CDesktop%5C9_padded_padded.png\",alt:\"9_padded_padded\"})]}),\"\\n\",n(i.h2,{id:\"总结\",children:\"总结\"}),\"\\n\",n(i.p,{children:\"如果用标量图，记得图像够大，让图像不要压缩即可。\"}),\"\\n\",n(i.p,{children:\"如果用矢量图，需要\"}),\"\\n\",e(i.ul,{children:[\"\\n\",n(i.li,{children:\"全选图像，「文本」中取消「自动换行」和「格式化文本」。手动换行\"}),\"\\n\",n(i.li,{children:\"draw.io 导出 SVG 时取消「嵌入字体」和「嵌入图像」，并添加一点边距\"}),\"\\n\"]}),\"\\n\",n(i.p,{children:\"这样 Word 转 SVG 为 PDF 时，文字可以保持矢量状态，而且可以被选中。\"})]})}return{default:function(d={}){const{wrapper:e}=d.components||{};return e?n(e,{...d,children:n(_createMdxContent,{...d})}):_createMdxContent(d)}};","toc",[29,35,39],{"_7":30,"_31":32,"_33":34},"使用像素图（PNG）","url","#使用像素图png","items",[],{"_7":36,"_31":37,"_33":38},"使用矢量图（SVG）","#使用矢量图svg",[],{"_7":40,"_31":41,"_33":42},"总结","#总结",[],"tags",[45],"教程","categories","工具","keywords",[],"permalink","/posts/2026-05-25-draw-io-svg-to-word-pdf-print","prevPost","nextPost",{"_7":55,"_9":56},"Windows 调整之中文字体","2023-09-29-windows-system-chinese-fonts-adjustment"]
