[{"_1":2},"routes/posts.$slug",{"_3":4},"data",{"_5":6,"_7":8,"_9":10},"post",{"_11":16,"_13":16,"_17":18,"_19":-5,"_20":21,"_22":23,"_24":25,"_26":27,"_28":29,"_30":31,"_32":33,"_34":35,"_36":37,"_38":39},"prevPost",{"_11":14,"_13":15},"nextPost",{"_11":12,"_13":12},"title","都挺好","slug","关于GFW的法律相关定罪之“非法获取计算机系统数据、非法控制计算机信息系统罪”","gwf-law","GlobalProtect启动退出脚本(MAC)","date","2020-03-26T16:00:00.000Z","description","draft",false,"metadata",{"_43":44,"_45":46},"excerpt","mac上的Global Protect近似于流氓软件，但迫于学校要求不得不用。于是写了个shell脚本。\n\n参考：Mac 退出与卸载 GlobalProtect\n\nif [ $# -eq 0 ]; then exit 0;fi\n\ncase \"$1\" in\n\t-h|--help) \n\t\techo \"-l\tlaunch\";\n\t\techo \"-k\tkill\";\n\t\techo \"-as\tlaunch and set autostart\";\n\t\techo \"-uas\tkill and unset autostart\";\n\t\t","content_html","<p>mac上的Global Protect近似于流氓软件，但迫于学校要求不得不用。于是写了个shell脚本。</p>\n<blockquote>\n<p>参考：<a href=\"https://zhuanlan.zhihu.com/p/121116869\">Mac 退出与卸载 GlobalProtect</a></p>\n</blockquote>\n<pre><code class=\"language-shell\">if [ $# -eq 0 ]; then exit 0;fi\n\ncase \"$1\" in\n\t-h|--help) \n\t\techo \"-l\tlaunch\";\n\t\techo \"-k\tkill\";\n\t\techo \"-as\tlaunch and set autostart\";\n\t\techo \"-uas\tkill and unset autostart\";\n\t\techo \"-h\thelp\";\n\t\texit 0;;\n\t-k)\n\t\tlaunchctl unload /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\n\t-l)\n\t\tlaunchctl load /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\n\t-uas)\n\t\tlaunchctl unload -w /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\n\t-as)\n\t\tlaunchctl load -w /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\nesac\n</code></pre>\n<p>在/usr/local/bin下新建文件，输入以上内容，并赋予执行权限即可。</p>","content_jsx","const{Fragment:t,jsx:n,jsxs:e}=arguments[0];function _createMdxContent(a){const c={a:\"a\",blockquote:\"blockquote\",code:\"code\",p:\"p\",pre:\"pre\",...a.components};return e(t,{children:[n(c.p,{children:\"mac上的Global Protect近似于流氓软件，但迫于学校要求不得不用。于是写了个shell脚本。\"}),\"\\n\",e(c.blockquote,{children:[\"\\n\",e(c.p,{children:[\"参考：\",n(c.a,{href:\"https://zhuanlan.zhihu.com/p/121116869\",children:\"Mac 退出与卸载 GlobalProtect\"})]}),\"\\n\"]}),\"\\n\",n(c.pre,{children:n(c.code,{className:\"hljs language-shell\",children:'if [ $# -eq 0 ]; then exit 0;fi\\n\\ncase \"$1\" in\\n\\t-h|--help) \\n\\t\\techo \"-l\\tlaunch\";\\n\\t\\techo \"-k\\tkill\";\\n\\t\\techo \"-as\\tlaunch and set autostart\";\\n\\t\\techo \"-uas\\tkill and unset autostart\";\\n\\t\\techo \"-h\\thelp\";\\n\\t\\texit 0;;\\n\\t-k)\\n\\t\\tlaunchctl unload /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\\n\\t-l)\\n\\t\\tlaunchctl load /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\\n\\t-uas)\\n\\t\\tlaunchctl unload -w /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\\n\\t-as)\\n\\t\\tlaunchctl load -w /Library/LaunchAgents/com.paloaltonetworks.gp.pangp*;exit 0;;\\nesac\\n'})}),\"\\n\",n(c.p,{children:\"在/usr/local/bin下新建文件，输入以上内容，并赋予执行权限即可。\"})]})}return{default:function(t={}){const{wrapper:e}=t.components||{};return e?n(e,{...t,children:n(_createMdxContent,{...t})}):_createMdxContent(t)}};","toc",[],"tags",[42],"categories","工具","keywords",[40,41],"permalink","/posts/GlobalProtect启动退出脚本(MAC)","GlobalProtect","shell脚本","开源项目","readingTime",1,"wordCount",112.80000000000001]
